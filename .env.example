# odoo-agent — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to the repository

# ─────────────────────────────────────────
# Odoo.sh SSH Connection
# Format: build_id@instance-name.dev.odoo.com
# Find this in Odoo.sh → your project → branch → SSH button
# ─────────────────────────────────────────
ODOO_SSH=your_build_id@your-instance.dev.odoo.com

# ─────────────────────────────────────────
# Odoo Database Name
# Find this in Odoo.sh → your project → branch name
# ─────────────────────────────────────────
ODOO_DB=your-database-name

# ─────────────────────────────────────────
# Your Custom Module Prefix
# All modules with this prefix are considered yours (read + write)
# Everything else is read-only
# Example: proyelec, mycompany, custom
# ─────────────────────────────────────────
MODULE_PREFIX=your_prefix

# ─────────────────────────────────────────
# Development Branch Name
# The agent will only operate on this branch
# ─────────────────────────────────────────
DEV_BRANCH=AIT

# ─────────────────────────────────────────
# Notes
# - SSH key must be registered in Odoo.sh → Settings → SSH Keys
# - The build ID changes monthly when staging is renewed
# - Update ODOO_SSH and ODOO_DB each time staging renews
# ─────────────────────────────────────────
